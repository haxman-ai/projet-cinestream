<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title><?= htmlspecialchars($film->getTitle() ?? 'Film sans titre') ?> - CineStream+</title>
</head>
<body>

<?php require __DIR__ . '/header.phtml'; ?>

<main class="container">
    <a href="index.php" class="btn-back">⬅ Retour à la vidéothèque</a>

    <?php if (isset($_GET['success']) && $_GET['success'] === 'updated') : ?>
        <p class="success-message">Le film a bien été modifié.</p>
    <?php endif; ?>

    <section class="movie-details">
        <div class="details-layout">

            <div class="details-poster">
                <img
                    src="https://image.tmdb.org/t/p/w500<?= htmlspecialchars($film->getPoster_path() ?? '') ?>"
                    alt="<?= htmlspecialchars($film->getTitle() ?? 'Film sans titre') ?>">
            </div>

            <div class="details-info">
                <h1><?= htmlspecialchars($film->getTitle() ?? 'Film sans titre') ?></h1>

                <div class="meta">
                    <span class="date">
                        📅 <?= htmlspecialchars($film->getRelease_date() ?? 'Date inconnue') ?>
                    </span>

                    <span class="rating">
                        ⭐ <?= $film->getVote_average() !== null
                            ? htmlspecialchars((string)$film->getVote_average()) . '/10'
                            : 'Non noté' ?>
                    </span>

                    <span class="status-badge <?= $film->getIsWatched() ? 'watched' : 'to-watch' ?>">
                        <?= $film->getIsWatched() ? '✅ Déjà vu' : '🕒 À regarder' ?>
                    </span>
                </div>

                <h3>Synopsis</h3>
                <p class="overview">
                    <?= !empty($film->getOverview())
                        ? htmlspecialchars($film->getOverview())
                        : 'Aucun résumé disponible pour ce film.' ?>
                </p>

                <div class="actions">
                    <a href="index.php?route=update&id=<?= $film->getId() ?>" class="btn-edit">
                        ✏️ Modifier la fiche
                    </a>

                    <a href="index.php?route=delete&id=<?= $film->getId() ?>"
                       class="btn-delete"
                       onclick="return confirmerSuppression(event, '<?= addslashes($film->getTitle() ?? 'ce film') ?>')">
                        ❌ Supprimer le film
                    </a>
                </div>
            </div>
        </div>
    </section>
</main>

<script>
function confirmerSuppression(event, titre) {
    const confirmation = confirm("Êtes-vous sûr de vouloir supprimer le film : " + titre + " ?");
    if (!confirmation) {
        event.preventDefault();
        return false;
    }
    return true;
}
</script>
</body>
</html>