<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css/style.css">
    <title>CineStream+ - Ma Vidéothèque</title>
</head>
<body>
<?php require 'header.phtml'; ?>

<nav class="filters">
    <a href="index.php?route=index" class="tag <?= !isset($_GET['id']) ? 'active' : '' ?>">
        Tous les films
    </a>

    <?php foreach ($genres as $genre) : ?>
        <a href="index.php?route=index&id=<?= $genre->getId() ?>" 
           class="tag <?= (isset($_GET['id']) && $_GET['id'] == $genre->getId()) ? 'active' : '' ?>">
            <?= htmlspecialchars($genre->getName()) ?>
        </a>
    <?php endforeach; ?>

    <a href="index.php?route=index&notcategorie=1" class="tag">nc</a>
    <a href="index.php?route=index&isWatched=1" class="tag">👁️</a>
    <a href="index.php?route=index&isWatched=0" class="tag">🕐</a>
</nav>

<?php if (empty($films)): ?>
    <p class="empty-msg">Votre vidéothèque est vide. Commencez votre collection !</p>
<?php else: ?>
<div class="movie-grid">
    <?php foreach ($films as $film): ?>
        <div class="movie-card">
            <a href="index.php?route=show&id=<?= $film->getId() ?>">
                <img src="https://image.tmdb.org/t/p/w500<?= htmlspecialchars($film->getPoster_path()) ?>" 
                     alt="<?= htmlspecialchars($film->getTitle()) ?>">
            </a>

            <div class="movie-card-body">
                <h3><?= htmlspecialchars($film->getTitle()) ?></h3>
                
                <p class="release-date">
                    <?= htmlspecialchars($film->getRelease_date()) ?> 📅
                </p>

                <div class="movie-status">
                    <?php if ($film->getIsWatched()): ?>
                        <span class="status-icon watched">Vu 👁️</span>
                    <?php else: ?>
                        <span class="status-icon to-watch">À voir 🕐</span>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    <?php endforeach; ?>
</div>
<?php endif; ?>

</body>
</html>